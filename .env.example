############################################
# OpenBrain Example Environment (.env.example)
# Copy to .env and fill in values
############################################

# LLM Providers
OPENAI_API_KEY=
# Optional: custom base URL (e.g., LiteLLM proxy)
OPENAI_BASE_URL=http://127.0.0.1:4000

# Optional providers
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# CORS (comma-separated)
# e.g. http://localhost:5173,http://127.0.0.1:5173
#CORS_ORIGINS=

